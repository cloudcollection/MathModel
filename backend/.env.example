# Set MOCK_LLM=true for local smoke tests without provider keys.
MOCK_LLM=true

# LiteLLM provider keys. Add the keys required by your selected model.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Agent model routing. Leave per-agent values empty to use DEFAULT_MODEL.
DEFAULT_MODEL=gpt-4.1
PLANNER_MODEL=
CODER_MODEL=
ANALYST_MODEL=
WRITER_MODEL=

# Runtime services.
REDIS_URL=redis://redis:6379/0
MAX_RETRY=3
JUPYTER_TIMEOUT=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

